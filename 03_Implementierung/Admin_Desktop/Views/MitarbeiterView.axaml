<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Admin_Desktop.ViewModels"
             x:DataType="vm:MitarbeiterViewModel"
             x:Class="Admin_Desktop.Views.MitarbeiterView">
   <Grid RowDefinitions="Auto,*">
       <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
           <TextBox Grid.Column="0" PlaceholderText="Suche..." Width="250" HorizontalAlignment="Left"></TextBox>
           <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
               <Button Classes="hinterlegt" Content="+ Neu"></Button>
               <Button Classes="hinterlegt" Content="Bearbeiten"></Button>
               <Button Classes="hinterlegt" Content="Deaktivieren"></Button>
           </StackPanel>
       </Grid>
       <DataGrid Grid.Row="1" ItemsSource="{Binding Mitarbeiter}" AutoGenerateColumns="False">
               <DataGrid.Columns>
                   <DataGridTextColumn Header="Vorname" Binding="{Binding Vorname}"/>
                   <DataGridTextColumn Header="Nachname" Binding="{Binding Nachname}"/>
                   <DataGridTextColumn Header="Personalnummer" Binding="{Binding Personalnummer}"/>
                   <DataGridTextColumn Header="Abteilung" Binding="{Binding Abteilung}"/>
                   <DataGridTextColumn Header="Rolle" Binding="{Binding Rolle}"/>
               </DataGrid.Columns>
       </DataGrid>
   </Grid>
    
    
</UserControl>